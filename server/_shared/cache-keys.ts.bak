     1|     1|// ── Story persistence tracking keys (E3) ─────────────────────────────────────
     2|     2|// Hash: firstSeen, lastSeen, mentionCount, sourceCount, currentScore, peakScore, title, link, severity, lang
     3|     3|export const STORY_TRACK_KEY_PREFIX = 'story:track:v1:';
     4|     4|// Set: unique feed names that have mentioned this story
     5|     5|export const STORY_SOURCES_KEY_PREFIX = 'story:sources:v1:';
     6|     6|// Sorted set: single member "peak" with score = highest importanceScore seen
     7|     7|export const STORY_PEAK_KEY_PREFIX = 'story:peak:v1:';
     8|     8|// Sorted set: accumulator for digest mode notifications (score = pubDate epoch ms)
     9|     9|export const DIGEST_ACCUMULATOR_KEY_PREFIX = 'digest:accumulator:v1:';
    10|    10|// TTL for all story tracking keys (48 hours)
    11|    11|export const STORY_TRACKING_TTL_S = 172800;
    12|    12|
    13|    13|/**
    14|    14| * Story tracking keys — written by list-feed-digest.ts, read by digest cron (E2).
    15|    15| * All keys use 32-char SHA-256 hex prefix of the normalised title as ${titleHash}.
    16|    16| *
    17|    17| *   story:track:v1:${titleHash}     Hash   firstSeen/lastSeen/title/link/severity/mentionCount/currentScore/lang
    18|    18| *   story:sources:v1:${titleHash}   Set    feed IDs (SADD per appearance)
    19|    19| *   story:peak:v1:${titleHash}      ZSet   single member "peak", score = highest importanceScore (ZADD GT)
    20|    20| *   digest:accumulator:v1:${variant}:${lang} ZSet  member=titleHash, score=lastSeen_ms (updated every appearance)
    21|    21| *
    22|    22| * TTL for all: 172800s (48h), refreshed each digest cycle.
    23|    23| * Shadow scoring key (written by notification-relay.cjs, which owns the live
    24|    24| * value — the constant here is documentation only, not imported):
    25|    25| *   shadow:score-log:v5            ZSet   score=epoch_ms, member=JSON{ts,importanceScore,severity,eventType,title,source,publishedAt,corroborationCount,variant}
    26|    26| *   shadow:score-log:v3            ZSet   legacy (weight rebalance) — self-prunes via 7d ZREMRANGEBYSCORE
    27|    27| *   shadow:score-log:v2            ZSet   legacy (stale-score fix) — self-prunes
    28|    28| *   shadow:score-log:v1            ZSet   legacy (pre-PR #3069) — self-prunes
    29|    29| */
    30|    30|export const STORY_TRACK_KEY = (titleHash: string) => `story:track:v1:${titleHash}`;
    31|    31|export const STORY_SOURCES_KEY = (titleHash: string) => `story:sources:v1:${titleHash}`;
    32|    32|export const STORY_PEAK_KEY = (titleHash: string) => `story:peak:v1:${titleHash}`;
    33|    33|export const DIGEST_ACCUMULATOR_KEY = (variant: string, lang = 'en') => `digest:accumulator:v1:${variant}:${lang}`;
    34|    34|export const DIGEST_LAST_SENT_KEY = (userId: string, variant: string) => `digest:last-sent:v1:${userId}:${variant}`;
    35|    35|// NOTE: notification-relay.cjs owns the live value (shadow:score-log:v5 since prompt upgrade).
    36|    36|// This export is documentation/discoverability; changing it here does NOT affect the relay.
    37|    37|// If you modify the key, also update scripts/notification-relay.cjs SHADOW_SCORE_LOG_KEY.
    38|    38|export const SHADOW_SCORE_LOG_KEY = 'shadow:score-log:v5';
    39|    39|export const STORY_TTL = 604800;           // 7 days — enough for sustained multi-day stories
    40|    40|export const DIGEST_ACCUMULATOR_TTL = 172800; // 48h — lookback window for digest content
    41|    41|
