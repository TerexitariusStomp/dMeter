    98|
    99|// Propaganda risk assessment for sources (Quick Win #5)
   100|// 'high' = State-controlled media, known to push government narratives
   101|// 'medium' = State-affiliated or known editorial bias toward specific governments
   102|// 'low' = Independent journalism with editorial standards
   103|export type PropagandaRisk = 'low' | 'medium' | 'high';
   104|
   105|export interface SourceRiskProfile {
   106|  risk: PropagandaRisk;
   107|  stateAffiliated?: string;
   108|  knownBiases?: string[];
   109|  note?: string;
   110|}
   111|
   112|export const SOURCE_PROPAGANDA_RISK: Record<string, SourceRiskProfile> = {
   113|  // High risk - State-controlled media
   114|  'Xinhua': { risk: 'high', stateAffiliated: 'China', note: 'Official CCP news agency' },
   115|  'TASS': { risk: 'high', stateAffiliated: 'Russia', note: 'Russian state news agency' },
   116|  'RT': { risk: 'high', stateAffiliated: 'Russia', note: 'Russian state media, banned in EU' },
   117|  'RT Russia': { risk: 'high', stateAffiliated: 'Russia', note: 'Russian state media, Russia desk' },
   118|  'Sputnik': { risk: 'high', stateAffiliated: 'Russia', note: 'Russian state media' },
   119|  'CGTN': { risk: 'high', stateAffiliated: 'China', note: 'Chinese state broadcaster' },
   120|  'Press TV': { risk: 'high', stateAffiliated: 'Iran', note: 'Iranian state media' },
   121|  'IRNA': { risk: 'high', stateAffiliated: 'Iran', note: 'Iranian state news agency (Islamic Republic News Agency)' },
   122|  'Mehr News': { risk: 'high', stateAffiliated: 'Iran', note: 'Iranian state-affiliated, Basij-linked' },
   123|  'KCNA': { risk: 'high', stateAffiliated: 'North Korea', note: 'North Korean state media' },
   124|
   125|  // Medium risk - State-affiliated or known bias
   126|  'Al Jazeera': { risk: 'medium', stateAffiliated: 'Qatar', note: 'Qatari state-funded, independent editorial' },
   127|  'Al Arabiya': { risk: 'medium', stateAffiliated: 'Saudi Arabia', note: 'Saudi-owned, reflects Gulf perspective' },
   128|  'TRT World': { risk: 'medium', stateAffiliated: 'Turkey', note: 'Turkish state broadcaster' },
   129|  'France 24': { risk: 'medium', stateAffiliated: 'France', note: 'French state-funded, editorially independent' },
   130|  'EuroNews': { risk: 'low', note: 'European public broadcaster consortium', knownBiases: ['Pro-EU'] },
   131|  'Le Monde': { risk: 'low', note: 'French newspaper of record' },
   132|  'DW News': { risk: 'medium', stateAffiliated: 'Germany', note: 'German state-funded, editorially independent' },
   133|  'Voice of America': { risk: 'medium', stateAffiliated: 'USA', note: 'US government-funded' },
   134|  'Kyiv Independent': { risk: 'medium', knownBiases: ['Pro-Ukraine'], note: 'Ukrainian perspective on Russia-Ukraine war' },
   135|  'Moscow Times': { risk: 'medium', knownBiases: ['Anti-Kremlin'], note: 'Independent, critical of Russian government' },
   136|
   137|  // Low risk - Independent with editorial standards (explicit)
   138|  'Jerusalem Post': { risk: 'low', knownBiases: ['Israeli centre-right'], note: 'English-language Israeli daily of record' },
   139|  'Ynetnews': { risk: 'low', knownBiases: ['Israeli mainstream'], note: 'Yedioth Ahronoth English edition' },
   140|  'Reuters': { risk: 'low', note: 'Wire service, strict editorial standards' },
   141|  'AP News': { risk: 'low', note: 'Wire service, nonprofit cooperative' },
   142|  'AFP': { risk: 'low', note: 'Wire service, editorially independent' },
   143|  'BBC World': { risk: 'low', note: 'Public broadcaster, editorial independence charter' },
   144|  'BBC Middle East': { risk: 'low', note: 'Public broadcaster, editorial independence charter' },
   145|  'Guardian World': { risk: 'low', knownBiases: ['Center-left'], note: 'Scott Trust ownership, no shareholders' },
   146|  'Financial Times': { risk: 'low', note: 'Business focus, Nikkei-owned' },
   147|  'Bellingcat': { risk: 'low', note: 'Open-source investigations, methodology transparent' },
   148|  'Brasil Paralelo': { risk: 'low', note: 'Independent media company: no political ties, no public funding, 100% subscriber-funded.' },
   149|};
   150|
   151|export function getSourcePropagandaRisk(sourceName: string): SourceRiskProfile {
   152|  return SOURCE_PROPAGANDA_RISK[sourceName] ?? { risk: 'low' };
   153|}
   154|
   155|export function isStateAffiliatedSource(sourceName: string): boolean {
   156|  const profile = SOURCE_PROPAGANDA_RISK[sourceName];
   157|  return !!profile?.stateAffiliated;
   158|}
   159|
   160|let _sourcePanelMap: Map<string, string> | null = null;
   161|export function getSourcePanelId(sourceName: string): string {
   162|  if (!_sourcePanelMap) {
   163|    _sourcePanelMap = new Map();
   164|    for (const [category, feeds] of Object.entries(FEEDS)) {
   165|      for (const feed of feeds) _sourcePanelMap.set(feed.name, category);
   166|    }
   167|    for (const feed of INTEL_SOURCES) _sourcePanelMap.set(feed.name, 'intel');
   168|  }
   169|  return _sourcePanelMap.get(sourceName) ?? 'politics';
   170|}
